# ============================================================================
# MindEase backend configuration. Copy to `.env` and fill in real values.
# `.env` is gitignored — never commit secrets.
# ============================================================================

# ---- Server ----
HOST=127.0.0.1
PORT=8000

# ---- CORS (comma-separated). Vite dev server runs on 5173. ----
FRONTEND_ORIGINS=http://localhost:5173,http://127.0.0.1:5173


# ---- NLP severity pipeline ----
# HuggingFace model id for the emotion classifier (RoBERTa-base / GoEmotions).
EMOTION_MODEL=SamLowe/roberta-base-go_emotions
# Set to 1 to skip loading the transformer and run the lexicon analyzer only
# (useful for CI / low-resource machines). Safety triggers still work.
DISABLE_ML_MODEL=0
# Safety/Crisis index strictly greater than this => Critical Distress trigger.
SAFETY_THRESHOLD=0.85

# ---- Agora.io (telehealth video) ----
# Create a project at https://console.agora.io to get these.
AGORA_APP_ID="your-agora-app-id"
AGORA_APP_CERTIFICATE="your-agora-app-certificate"
AGORA_TOKEN_EXPIRY_SECONDS=3600

# ---- Firebase Admin (Phase 4: auth verification + server Firestore) ----
# Path (relative to backend/) to the service-account JSON. The default matches
# the file the rest of the project already uses. Keep it gitignored.
FIREBASE_CREDENTIALS=firebase-config.json

# ---- Clinical cryptography (Phase 4) ----
# AES-256 master key used to encrypt clinical fields (sessionNotes, diagnosis,
# prescriptions) and to seal doctor private keys at rest. MUST be set for the
# /api/sessions/complete flow. Generate a fresh 32-byte key with:
#   python -c "import os,base64;print(base64.b64encode(os.urandom(32)).decode())"
# Rotating this key makes previously-encrypted data unreadable — back it up.
CLINICAL_MASTER_KEY="your-base64-32-byte-master-key-here"
