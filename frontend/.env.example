# Base URL of the FastAPI backend (no trailing slash). Backend runs on :8000.
VITE_API_URL=http://127.0.0.1:8000
# Optional explicit WebSocket base. Derived from VITE_API_URL if omitted.
# VITE_WS_URL=ws://127.0.0.1:8000

# ---- Firebase Web App config -------------------------------------------------
# These are the *client* credentials (safe to ship to the browser), NOT the
# Admin service account in backend/firebase-config.json. Copy them from:
#   Firebase console → Project settings → General → "Your apps" → Web app → SDK setup.
VITE_FIREBASE_API_KEY=your-web-api-key
VITE_FIREBASE_AUTH_DOMAIN=mindease-4749c.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=mindease-4749c
VITE_FIREBASE_STORAGE_BUCKET=mindease-4749c.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
VITE_FIREBASE_APP_ID=your-app-id
